cflags = -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /home/sht/anaconda3/envs/perascdnew/include -fPIC -O2 -isystem /home/sht/anaconda3/envs/perascdnew/include -fPIC -DWITH_CUDA -I/data2/sht/Codes/PerASCD/models/pera_layers/vit_adapter_layers/ops/src -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include/TH -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include/THC -I/home/sht/anaconda3/envs/perascdnew/include -I/home/sht/anaconda3/envs/perascdnew/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -DWITH_CUDA -I/data2/sht/Codes/PerASCD/models/pera_layers/vit_adapter_layers/ops/src -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include/TH -I/home/sht/anaconda3/envs/perascdnew/lib/python3.10/site-packages/torch/include/THC -I/home/sht/anaconda3/envs/perascdnew/include -I/home/sht/anaconda3/envs/perascdnew/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DCUDA_HAS_FP16=1 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_89,code=sm_89 -ccbin /home/sht/anaconda3/envs/perascdnew/bin/x86_64-conda-linux-gnu-gcc -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





